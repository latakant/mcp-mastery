# Day 3 — GitHub Intelligence Server
GITHUB_TOKEN=                  # Personal access token — github.com/settings/tokens

# Day 5 — HTTP Database Server
DB_PATH=                       # Absolute path to SQLite file e.g. ./data/dev.db
AUTH_TOKEN=                    # Bearer token for HTTP transport auth

# Day 6 — DevOps Server
PROJECT_ROOT=                  # Absolute path to the project being governed
LOG_DIR=                       # Absolute path to log directory
TEST_COMMAND=                  # e.g. npm test or npx jest
